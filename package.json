{
  "name": "@rkobuki/kanji-lint",
  "version": "0.1.0",
  "description": "Detect kanji outside the joyo kanji list in text and Markdown manuscripts.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "kanji-lint": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
